// Prisma schema for Shop Management System (Enterprise)
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// TENANCY
// ─────────────────────────────────────────────

model ShopUser {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  phone        String   @default("")
  shopName     String   @map("shop_name")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  users              User[]
  products           Product[]
  categories         Category[]
  customers          Customer[]
  sales              Sale[]
  saleItems          SaleItem[]
  payments           Payment[]
  withdrawals        Withdrawal[]
  expenses           Expense[]
  shareholders       ShareHolder[]
  suppliers          Supplier[]
  supplierPurchases  SupplierPurchase[]
  supplierPayments   SupplierPayment[]
  activityLogs       ActivityLog[]
  cashLedger         CashLedger?
  refreshTokens      RefreshToken[]

  @@map("shop_users")
}

model RefreshToken {
  id         String    @id @default(uuid())
  token      String    @unique
  shopUserId String?   @map("shop_user_id")
  userId     String?   @map("user_id")
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  shopUser   ShopUser? @relation(fields: [shopUserId], references: [id], onDelete: Cascade)
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// AUTH & USERS (per shop)
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  shopId       String   @map("shop_id")
  username     String
  email        String
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  role         UserRole @default(USER)
  isActive     Boolean  @default(true) @map("is_active")
  permissions  String[] @default([])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  shop         ShopUser      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  activityLogs ActivityLog[]
  refreshTokens RefreshToken[]

  @@unique([shopId, username])
  @@unique([shopId, email])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  USER
}

// ─────────────────────────────────────────────
// PRODUCTS & CATEGORIES
// ─────────────────────────────────────────────

model Category {
  id          String    @id @default(uuid())
  shopId      String    @map("shop_id")
  nameEn      String    @map("name_en")
  nameFa      String    @map("name_fa")
  description String    @default("")
  createdAt   DateTime  @default(now()) @map("created_at")

  shop        ShopUser  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products    Product[]

  @@map("categories")
}

model Product {
  id           String     @id @default(uuid())
  shopId       String     @map("shop_id")
  name         String
  categoryId   String?    @map("category_id")
  barcode      String?
  buyPriceAfn  Decimal    @default(0) @map("buy_price_afn") @db.Decimal(14, 2)
  buyPriceUsd  Decimal    @default(0) @map("buy_price_usd") @db.Decimal(14, 2)
  sellPriceAfn Decimal    @default(0) @map("sell_price_afn") @db.Decimal(14, 2)
  sellPriceUsd Decimal    @default(0) @map("sell_price_usd") @db.Decimal(14, 2)
  stock        Int        @default(0)
  minStock     Int        @default(0) @map("min_stock")
  description  String     @default("")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  shop         ShopUser   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category     Category?  @relation(fields: [categoryId], references: [id])
  saleItems    SaleItem[]

  @@index([shopId, barcode])
  @@map("products")
}

// ─────────────────────────────────────────────
// CUSTOMERS & SALES
// ─────────────────────────────────────────────

model Customer {
  id          String       @id @default(uuid())
  shopId      String       @map("shop_id")
  name        String
  phone       String       @default("")
  address     String       @default("")
  balanceAfn  Decimal      @default(0) @map("balance_afn") @db.Decimal(14, 2)
  balanceUsd  Decimal      @default(0) @map("balance_usd") @db.Decimal(14, 2)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  shop        ShopUser     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  sales       Sale[]
  payments    Payment[]
  withdrawals Withdrawal[]

  @@map("customers")
}

model Sale {
  id              String        @id @default(uuid())
  shopId          String        @map("shop_id")
  customerId      String        @map("customer_id")
  invoiceNumber   String?       @map("invoice_number")
  currency        Currency      @default(AFN)
  totalAmount     Decimal       @map("total_amount") @db.Decimal(14, 2)
  discount        Decimal       @default(0) @db.Decimal(14, 2)
  paidAmount      Decimal       @default(0) @map("paid_amount") @db.Decimal(14, 2)
  remainingAmount Decimal       @default(0) @map("remaining_amount") @db.Decimal(14, 2)
  paymentStatus   PaymentStatus @default(CREDIT) @map("payment_status")
  saleDate        DateTime      @default(now()) @map("sale_date")
  createdAt       DateTime      @default(now()) @map("created_at")

  shop            ShopUser      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer        Customer      @relation(fields: [customerId], references: [id])
  items           SaleItem[]

  @@index([shopId, customerId])
  @@map("sales")
}

model SaleItem {
  id        String   @id @default(uuid())
  shopId    String   @map("shop_id")
  saleId    String   @map("sale_id")
  productId String   @map("product_id")
  quantity  Int
  price     Decimal  @db.Decimal(14, 2)

  shop      ShopUser @relation(fields: [shopId], references: [id], onDelete: Cascade)
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])

  @@map("sale_items")
}

model Payment {
  id         String   @id @default(uuid())
  shopId     String   @map("shop_id")
  customerId String   @map("customer_id")
  amount     Decimal  @db.Decimal(14, 2)
  currency   Currency @default(AFN)
  note       String   @default("")
  paidAt     DateTime @default(now()) @map("paid_at")

  shop       ShopUser @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id])

  @@map("payments")
}

// ─────────────────────────────────────────────
// FINANCIALS
// ─────────────────────────────────────────────

model Withdrawal {
  id         String           @id @default(uuid())
  shopId     String           @map("shop_id")
  category   WithdrawalCategory
  personName String           @map("person_name")
  customerId String?          @map("customer_id")
  amountAfn  Decimal          @default(0) @map("amount_afn") @db.Decimal(14, 2)
  amountUsd  Decimal          @default(0) @map("amount_usd") @db.Decimal(14, 2)
  description String          @default("")
  withdrawnAt DateTime        @default(now()) @map("withdrawn_at")

  shop       ShopUser         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer   Customer?        @relation(fields: [customerId], references: [id])

  @@map("withdrawals")
}

model Expense {
  id          String   @id @default(uuid())
  shopId      String   @map("shop_id")
  category    String
  description String   @default("")
  amountAfn   Decimal  @default(0) @map("amount_afn") @db.Decimal(14, 2)
  amountUsd   Decimal  @default(0) @map("amount_usd") @db.Decimal(14, 2)
  expenseDate DateTime @default(now()) @map("expense_date")

  shop        ShopUser @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

model ShareHolder {
  id                 String   @id @default(uuid())
  shopId             String   @map("shop_id")
  name               String
  phone              String   @default("")
  address            String   @default("")
  investmentAmountAfn Decimal @default(0) @map("investment_amount_afn") @db.Decimal(14, 2)
  investmentAmountUsd Decimal @default(0) @map("investment_amount_usd") @db.Decimal(14, 2)
  sharePercentage    Decimal  @default(0) @map("share_percentage") @db.Decimal(5, 2)
  monthlyProfitAfn   Decimal  @default(0) @map("monthly_profit_afn") @db.Decimal(14, 2)
  monthlyProfitUsd   Decimal  @default(0) @map("monthly_profit_usd") @db.Decimal(14, 2)
  remainingProfitAfn Decimal  @default(0) @map("remaining_profit_afn") @db.Decimal(14, 2)
  remainingProfitUsd Decimal  @default(0) @map("remaining_profit_usd") @db.Decimal(14, 2)
  createdAt          DateTime @default(now()) @map("created_at")

  shop               ShopUser @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("shareholders")
}

model CashLedger {
  id       String   @id @default(uuid())
  shopId   String   @unique @map("shop_id")
  balanceAfn Decimal @default(0) @map("balance_afn") @db.Decimal(14, 2)
  balanceUsd Decimal @default(0) @map("balance_usd") @db.Decimal(14, 2)
  updatedAt DateTime @updatedAt @map("updated_at")

  shop     ShopUser @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("cash_ledger")
}

// ─────────────────────────────────────────────
// SUPPLIERS
// ─────────────────────────────────────────────

model Supplier {
  id          String             @id @default(uuid())
  shopId      String             @map("shop_id")
  name        String
  companyName String             @default("") @map("company_name")
  phone       String             @default("")
  address     String             @default("")
  balanceAfn  Decimal            @default(0) @map("balance_afn") @db.Decimal(14, 2)
  balanceUsd  Decimal            @default(0) @map("balance_usd") @db.Decimal(14, 2)
  createdAt   DateTime           @default(now()) @map("created_at")

  shop        ShopUser           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  purchases   SupplierPurchase[]
  payments    SupplierPayment[]

  @@map("suppliers")
}

model SupplierPurchase {
  id             String          @id @default(uuid())
  shopId         String          @map("shop_id")
  supplierId     String          @map("supplier_id")
  totalAmountAfn Decimal         @default(0) @map("total_amount_afn") @db.Decimal(14, 2)
  totalAmountUsd Decimal         @default(0) @map("total_amount_usd") @db.Decimal(14, 2)
  paidAmountAfn  Decimal         @default(0) @map("paid_amount_afn") @db.Decimal(14, 2)
  paidAmountUsd  Decimal         @default(0) @map("paid_amount_usd") @db.Decimal(14, 2)
  items          Json            @default("[]")
  description    String          @default("")
  purchaseDate   DateTime        @default(now()) @map("purchase_date")

  shop           ShopUser        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  supplier       Supplier        @relation(fields: [supplierId], references: [id])

  @@map("supplier_purchases")
}

model SupplierPayment {
  id         String   @id @default(uuid())
  shopId     String   @map("shop_id")
  supplierId String   @map("supplier_id")
  amountAfn  Decimal  @default(0) @map("amount_afn") @db.Decimal(14, 2)
  amountUsd  Decimal  @default(0) @map("amount_usd") @db.Decimal(14, 2)
  note       String   @default("")
  paidAt     DateTime @default(now()) @map("paid_at")

  shop       ShopUser @relation(fields: [shopId], references: [id], onDelete: Cascade)
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  @@map("supplier_payments")
}

// ─────────────────────────────────────────────
// AUDIT
// ─────────────────────────────────────────────

model ActivityLog {
  id          String     @id @default(uuid())
  shopId      String     @map("shop_id")
  userId      String     @map("user_id")
  username    String
  fullName    String     @map("full_name")
  action      AuditAction
  entity      String
  entityName  String     @map("entity_name")
  entityId    String?    @map("entity_id")
  description String
  beforeData  Json?      @map("before_data")
  afterData   Json?      @map("after_data")
  createdAt   DateTime   @default(now()) @map("created_at")

  shop        ShopUser   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id])

  @@index([shopId, createdAt(sort: Desc)])
  @@map("activity_logs")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Currency {
  AFN
  USD
}

enum PaymentStatus {
  PAID
  CREDIT
  PARTIAL
}

enum WithdrawalCategory {
  SHAREHOLDER
  CUSTOMER
}

enum AuditAction {
  ADD
  EDIT
  DELETE
}
